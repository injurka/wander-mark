{
  "name": "@injurka/wander-mark-server",
  "type": "module",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "bun": ">=1.1.30"
  },
  "scripts": {
    "start": "bun src/index.ts",
    "--------------------------------<      DEV       >--------------------------------": "",
    "dev": "bun --watch src/index.ts",
    "--------------------------------<      BUILD     >--------------------------------": "",
    "build": "bun build ./src/index.ts --outdir ./dist --target bun --no-minify",
    "--------------------------------< LINT & FORMAT >---------------------------------": "",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "bunx tsc --noEmit"
  },
  "dependencies": {},
  "devDependencies": {
    "@antfu/eslint-config": "7.7.0",
    "@types/bun": "latest",
    "bun": "^1.3.10",
    "bun-types": "^1.3.10",
    "eslint": "10.0.3",
    "eslint-plugin-format": "2.0.1",
    "typescript": "5.9.3"
  }
}
