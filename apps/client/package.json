{
  "name": "@injurkx/wander-mark-client",
  "type": "module",
  "version": "1.0.0",
  "private": true,
  "description": "Obsidian Client Application",
  "author": {
    "name": "Ivan Kornilov",
    "email": "injurka@gmail.com"
  },
  "engines": {
    "bun": ">=1.2.0"
  },
  "scripts": {
    "--------------------------------<      DEV       >--------------------------------": "",
    "dev": "vite --config build/vite.config.web.ts",
    "--------------------------------<      BUILD     >--------------------------------": "",
    "build": "vite build --config build/vite.config.web.ts",
    "preview": "vite preview --config build/vite.config.web.ts",
    "--------------------------------<   TAURI   >---------------------------------": "",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "tauri:build:linux:x64": "tauri build --target x86_64-unknown-linux-gnu",
    "tauri:build:win:x64": "tauri build --target x86_64-pc-windows-msvc",
    "--------------------------------<   CAPACITOR   >---------------------------------": "",
    "cap:sync": "bun run build && bunx cap sync",
    "cap:open:android": "bunx cap open android",
    "cap:open:ios": "bunx cap open ios",
    "cap:run:android": "bunx cap run android",
    "cap:run:ios": "bunx cap run ios",
    "cap:asset": "capacitor-assets generate",
    "--------------------------------< LINT & FORMAT >---------------------------------": "",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "vue-tsc --noEmit",
    "--------------------------------<     UTILS     >---------------------------------": "",
    "icons:bundle": "bun run build/bundle-icons.ts"
  },
  "dependencies": {
    "@capacitor/android": "^8.0.2",
    "@capacitor/core": "^8.0.2",
    "@capacitor/filesystem": "^6.0.0",
    "@iconify-icons/mdi": "^1.2.48",
    "@tauri-apps/api": "^2.0.0",
    "@tauri-apps/plugin-dialog": "^2.0.0",
    "@tauri-apps/plugin-fs": "^2.0.0",
    "@tauri-apps/plugin-http": "^2.5.7",
    "@tauri-apps/plugin-opener": "^2.0.0",
    "@vueuse/core": "^14.2.1",
    "@vueuse/head": "^2.0.0",
    "fuse.js": "^7.1.0",
    "idb-keyval": "^6.2.1",
    "markdown-it": "14.1.1",
    "markdown-it-attrs": "4.3.1",
    "markdown-it-collapsible": "2.0.2",
    "markdown-it-container": "4.0.0",
    "markdown-it-obsidian-callouts": "0.3.3",
    "pinia": "3.0.4",
    "shiki": "^4.0.2",
    "vue": "^3.5.30",
    "vue-router": "^4.0.0"
  },
  "devDependencies": {
    "@antfu/eslint-config": "7.7.2",
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^8.0.2",
    "@iconify-json/mdi": "^1.2.3",
    "@iconify/utils": "^3.1.0",
    "@iconify/vue": "^5.0.0",
    "@tauri-apps/cli": "^2.0.0",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^24.10.1",
    "@vitejs/plugin-vue": "^5.0.0",
    "eslint": "9.0.0",
    "eslint-plugin-format": "2.0.1",
    "rollup-plugin-visualizer": "^5.12.0",
    "sass": "1.77.0",
    "typescript": "5.4.5",
    "unplugin-auto-import": "^0.17.6",
    "unplugin-icons": "^0.19.0",
    "unplugin-vue-components": "^0.27.0",
    "vite": "^5.2.0",
    "vite-plugin-compression2": "^1.1.0",
    "vitest": "^1.6.0",
    "vue-tsc": "^2.0.19"
  }
}
